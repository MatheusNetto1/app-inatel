{
  "name": "app-inatel",
  "version": "1.0.0",
  "description": "Protótipo frontend para a disciplina de Interação Homem-Máquina (IHM) — módulo de tesouraria e documentos.",
  "type": "module",
  "scripts": {
    "dev":              "vite",
    "test:unit":        "vitest run",
    "test:unit:watch":  "vitest",
    "test:unit:cov":    "vitest run --coverage",
    "test:e2e":         "playwright test",
    "test:e2e:ui":      "playwright test --ui",
    "test:e2e:debug":   "playwright test --debug",
    "test":             "vitest run && playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatheusNetto1/app-inatel.git"
  },
  "keywords": ["frontend", "ihm", "inatel"],
  "author": "Matheus Netto",
  "license": "MIT",
  "bugs":     { "url": "https://github.com/MatheusNetto1/app-inatel/issues" },
  "homepage": "https://github.com/MatheusNetto1/app-inatel#readme",
  "devDependencies": {
    "@playwright/test":   "^1.44.0",
    "@vitest/coverage-v8": "^1.6.0",
    "vite":               "^5.4.0",
    "vitest":             "^1.6.0"
  }
}